{
  "entities": {
    "User": {
      "title": "User",
      "description": "Registered citizen profile",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "address": { "type": "string" },
        "role": { "type": "string", "enum": ["citizen", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Complaint": {
      "title": "Complaint",
      "description": "Civic grievance submitted by a citizen",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "category": { "type": "string", "enum": ["electricity", "water", "roads", "garbage", "traffic", "property_tax", "other"] },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "in_progress", "resolved", "rejected"] },
        "location": { "type": "string" },
        "attachments": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "ChatMessage": {
      "title": "ChatMessage",
      "description": "A single message in a chat conversation",
      "type": "object",
      "properties": {
        "role": { "type": "string", "enum": ["user", "assistant"] },
        "content": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "ChatSession": {
       "title": "ChatSession",
       "description": "A conversation between a user and the AI assistant",
       "type": "object",
       "properties": {
         "userId": { "type": "string" },
         "title": { "type": "string" },
         "createdAt": { "type": "string", "format": "date-time" },
         "updatedAt": { "type": "string", "format": "date-time" }
       }
    },
    "CivicDoc": {
      "title": "CivicDoc",
      "description": "Knowledge base document for RAG",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "category": { "type": "string" },
        "keywords": { "type": "array", "items": { "type": "string" } }
      }
    }
  },
  "firestore": {
    "/users/{userId}": { "schema": "User", "description": "Citizen profiles" },
    "/complaints/{complaintId}": { "schema": "Complaint", "description": "Civic complaints" },
    "/chats/{chatId}": { "schema": "ChatSession", "description": "Chat sessions" },
    "/chats/{chatId}/messages/{messageId}": { "schema": "ChatMessage", "description": "Messages in a session" },
    "/knowledge_base/{docId}": { "schema": "CivicDoc", "description": "Knowledge base for AI context" }
  }
}
