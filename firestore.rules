rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // Common Helpers
    function isGuest(userId) { return userId == 'guest_user'; }
    function isSignedIn() { return request.auth != null; }
    function effectiveUserId() { return isSignedIn() ? request.auth.uid : 'guest_user'; }
    function isOwner(userId) { return effectiveUserId() == userId; }
    function isAdmin() { 
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid)); 
    }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // User Profile Rules
    match /users/{userId} {
      function isValidUser(data) {
        return data.keys().hasAll(['uid', 'email', 'role']) &&
               data.uid == effectiveUserId() &&
               data.email is string &&
               data.role in ['citizen', 'admin'];
      }
      
      allow get: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && (isGuest(userId) || isValidUser(incoming()));
      allow update: if isOwner(userId) && (isGuest(userId) || isValidUser(incoming())) && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'address', 'phoneNumber']);
    }

    // Complaints Rules
    match /complaints/{complaintId} {
      function isValidComplaint(data) {
        return data.keys().hasAll(['userId', 'category', 'title', 'status', 'createdAt']) &&
               data.userId == effectiveUserId() &&
               data.category in ['electricity', 'water', 'roads', 'garbage', 'traffic', 'property_tax', 'other'] &&
               data.status in ['pending', 'in_progress', 'resolved', 'rejected'];
      }

      allow list: if isOwner(resource.data.userId) || isAdmin();
      allow get: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isValidComplaint(incoming());
      allow update: if (
        // Citizen can update details if pending
        (isOwner(existing().userId) && existing().status == 'pending' && 
         incoming().diff(existing()).affectedKeys().hasOnly(['title', 'description', 'location'])) ||
        // Admin can update status
        (isAdmin() && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt']))
      );
    }

    // Chat Rules
    match /chats/{chatId} {
      allow list, get: if isOwner(resource.data.userId) || isAdmin();
      allow create: if incoming().userId == effectiveUserId();
      allow update: if isOwner(existing().userId) && incoming().userId == effectiveUserId();

      match /messages/{messageId} {
        allow list, get: if isOwner(get(/databases/$(database)/documents/chats/$(chatId)).data.userId);
        allow create: if isOwner(get(/databases/$(database)/documents/chats/$(chatId)).data.userId);
      }
    }

    // Knowledge Base (RAG context)
    match /knowledge_base/{docId} {
      allow read: if true; // Publicly readable for assistant
      allow write: if isAdmin();
    }
    
    // System admins collection
    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if false; // Only manageable through consoles or scripts
    }
  }
}
